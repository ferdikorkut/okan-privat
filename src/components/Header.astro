---
interface Props {
  lang?: string;
  overlay?: boolean;
}
const { lang = 'de', overlay = false } = Astro.props;

const nav = {
  de: [
    { label: 'Startseite', href: `/` },
    { label: 'Über mich',  href: `/#ueber-mich` },
    { label: 'Leistungen', href: `/#leistungen` },
    { label: 'Portfolio',  href: `/portfolio` },
    { label: 'Blog',       href: `/blog` },
    { label: 'Kontakt',    href: `/kontakt` },
  ],
  en: [
    { label: 'Home',     href: `/en/` },
    { label: 'About',    href: `/en/#about` },
    { label: 'Services', href: `/en/#services` },
    { label: 'Portfolio',href: `/en/portfolio` },
    { label: 'Blog',     href: `/en/blog` },
    { label: 'Contact',  href: `/en/contact` },
  ],
  tr: [
    { label: 'Ana Sayfa', href: `/tr/` },
    { label: 'Hakkımda',  href: `/tr/#hakkimda` },
    { label: 'Hizmetler', href: `/tr/#hizmetler` },
    { label: 'Portföy',   href: `/tr/portfolyo` },
    { label: 'Blog',      href: `/tr/blog` },
    { label: 'İletişim',  href: `/tr/iletisim` },
  ],
};

const links = nav[lang as keyof typeof nav] ?? nav.de;
const logoHref = lang === 'de' ? '/' : `/${lang}/`;
---

<header class={`header${overlay ? ' header--overlay' : ''}`}>
  <div class="header__inner">
    <a href={logoHref} class="header__logo">Okan Lülleci</a>

    <button class="header__burger" aria-label="Menü" aria-expanded="false" aria-controls="nav-menu">
      <span></span>
      <span></span>
      <span></span>
    </button>

    <nav class="header__nav" id="nav-menu" aria-label="Hauptnavigation">
      <ul>
        {links.map(link => (
          <li><a href={link.href}>{link.label}</a></li>
        ))}
      </ul>
    </nav>
  </div>
</header>

<script>
  const burger = document.querySelector('.header__burger') as HTMLButtonElement;
  const nav = document.querySelector('.header__nav') as HTMLElement;
  const header = document.querySelector('.header--overlay') as HTMLElement;

  burger?.addEventListener('click', () => {
    const isOpen = nav.classList.toggle('is-open');
    burger.setAttribute('aria-expanded', String(isOpen));
  });

  if (header) {
    const topbarHeight = 32;
    window.addEventListener('scroll', () => {
      const top = Math.max(0, topbarHeight - window.scrollY);
      header.style.top = `${top}px`;
    }, { passive: true });
  }
</script>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 100;
    background-color: var(--color-dark);
    color: var(--color-white);
  }

  .header--overlay {
    position: fixed;
    top: 32px;
    left: 0;
    width: 100%;
    background-color: rgba(41, 40, 39, 0.7);
  }

  .header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 1.25rem;
    max-width: 1280px;
    margin: 0 auto;
    gap: 2rem;
  }

  .header__logo {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1.1rem;
    letter-spacing: 0.02em;
    color: var(--color-white);
  }

  .header__burger {
    display: flex;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
  }

  .header__burger span {
    display: block;
    width: 24px;
    height: 2px;
    background-color: var(--color-white);
    transition: transform 0.3s, opacity 0.3s;
  }

  .header__nav {
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    width: 75%;
    background-color: var(--color-white);
    border-radius: 0 0 5px 5px;
    padding: 0 1.25rem;
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.35s ease, padding 0.35s ease;
  }

  .header__nav.is-open {
    max-height: 400px;
    padding: 1.25rem 1.25rem 1.75rem;
    border-top: 3px solid var(--color-red);
    border-right: 1px solid var(--color-red);
    border-bottom: 1px solid var(--color-red);
    border-left: 1px solid var(--color-red);
  }

  .header__nav ul {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
  }

  .header__nav a {
    font-family: var(--font-heading);
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-dark);
    transition: color 0.2s;
  }

  .header__nav a:hover {
    color: var(--color-red);
  }

  @media (min-width: 768px) {
    .header__burger {
      display: none;
    }

    .header__nav {
      display: block;
      position: static;
      background: none;
      border: none !important;
      padding: 0;
      max-height: none;
      overflow: visible;
      margin-left: auto;
      width: auto;
      left: auto;
      transform: none;
    }

    .header__nav ul {
      flex-direction: row;
      gap: 2rem;
      justify-content: flex-end;
    }

    .header__nav a {
      color: var(--color-white);
    }
  }
</style>
