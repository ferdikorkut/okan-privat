---
interface Props {
  overlay?: boolean;
}
const { overlay = false } = Astro.props;
---

<div class={`topbar${overlay ? ' topbar--overlay' : ''}`}>
  <div class="topbar__inner">
    <a href="tel:+490000000000" class="topbar__item">
      <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M6.62 10.79a15.05 15.05 0 0 0 6.59 6.59l2.2-2.2a1 1 0 0 1 1.02-.24 11.36 11.36 0 0 0 3.56.57 1 1 0 0 1 1 1V20a1 1 0 0 1-1 1C10.61 21 3 13.39 3 4a1 1 0 0 1 1-1h3.5a1 1 0 0 1 1 1c0 1.25.2 2.45.57 3.56a1 1 0 0 1-.25 1.03l-2.2 2.2z"/></svg>
      +49 000 000 00 00
    </a>
    <a href="mailto:info@okanlulleci.de" class="topbar__item">
      <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M20 4H4a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2zm0 4.7-8 5.03L4 8.7V6.87l8 5.03 8-5.03V8.7z"/></svg>
      info@okanlulleci.de
    </a>
  </div>
</div>

<style>
  .topbar {
    background-color: var(--color-dark);
    color: var(--color-cream);
    padding: 0.4rem 1.25rem;
  }

  .topbar--overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 200;
    background-color: rgba(41, 40, 39, 0.5);
  }

  .topbar__inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.25rem;
    font-size: 0.8rem;
  }

  @media (min-width: 768px) {
    .topbar__inner {
      justify-content: flex-start;
    }
  }

  .topbar__item {
    color: var(--color-cream);
    font-family: var(--font-body);
    display: flex;
    align-items: center;
    gap: 0.4rem;
    transition: color 0.2s;
  }

  .topbar__item:hover {
    color: var(--color-white);
  }
</style>
