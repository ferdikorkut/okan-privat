<style>
  .container { max-width: 800px; margin: 0 auto; padding: 0 1.25rem; }
  .section { padding: 4rem 0; }
  .page-title { font-size: clamp(1.5rem, 5vw, 2.25rem); margin-bottom: 2rem; }
  .content { line-height: 1.8; }
  .content p { margin-bottom: 1rem; }
</style>
