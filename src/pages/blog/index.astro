---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Blog – Okan Lülleci" lang="de">
  <section class="section">
    <div class="container">
      <h1 class="page-title">Blog</h1>
      <ul class="post-list">
        <!-- Blog yazıları buraya gelecek -->
        <li class="post-item">
          <span class="post-item__date">01.01.2025</span>
          <a href="/blog/beispiel-beitrag" class="post-item__title">Beispielbeitrag Titel</a>
        </li>
      </ul>
    </div>
  </section>
</Layout>

<style>
  .container {
    max-width: 800px;
    margin: 0 auto;
    padding: 0 1.25rem;
  }

  .section {
    padding: 4rem 0;
  }

  .page-title {
    font-size: clamp(1.75rem, 6vw, 2.75rem);
    margin-bottom: 2rem;
  }

  .post-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .post-item {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding: 1.25rem 0;
    border-bottom: 1px solid var(--color-cream);
  }

  .post-item__date {
    font-size: 0.8rem;
    color: var(--color-steel);
    font-family: var(--font-body);
  }

  .post-item__title {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 1.05rem;
    color: var(--color-dark);
    transition: color 0.2s;
  }

  .post-item__title:hover {
    color: var(--color-red);
  }
</style>
