---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Kontakt – Okan Lülleci" lang="de">
  <section class="section">
    <div class="container">
      <h1 class="page-title">Kontakt</h1>

      <div class="contact-grid">
        <!-- MESAJ FORMU -->
        <div class="contact-block">
          <h2 class="block-title">Nachricht senden</h2>
          <form class="form" action="https://formspree.io/f/FORMSPREE_ID" method="POST">
            <div class="form__group">
              <label for="name">Name</label>
              <input type="text" id="name" name="name" required />
            </div>
            <div class="form__group">
              <label for="email">E-Mail</label>
              <input type="email" id="email" name="email" required />
            </div>
            <div class="form__group">
              <label for="message">Nachricht</label>
              <textarea id="message" name="message" rows="5" required></textarea>
            </div>
            <button type="submit" class="btn">Absenden</button>
          </form>
        </div>

        <!-- RANDEVU TAKVİMİ -->
        <div class="contact-block contact-block--last">
          <div class="cal-header">
            <h2 class="block-title">Termin vereinbaren</h2>
            <p class="block-desc">Wählen Sie einen freien Termin – ich melde mich zur Bestätigung.</p>
          </div>
          <div class="cal-wrapper">
            <div style="width:100%;height:100%;overflow:scroll" id="my-cal-inline-30min"></div>
          </div>
        </div>
      </div>

    </div>
  </section>
<script type="text/javascript">
  (function (C, A, L) { let p = function (a, ar) { a.q.push(ar); }; let d = C.document; C.Cal = C.Cal || function () { let cal = C.Cal; let ar = arguments; if (!cal.loaded) { cal.ns = {}; cal.q = cal.q || []; d.head.appendChild(d.createElement("script")).src = A; cal.loaded = true; } if (ar[0] === L) { const api = function () { p(api, arguments); }; const namespace = ar[1]; api.q = api.q || []; if(typeof namespace === "string"){cal.ns[namespace] = cal.ns[namespace] || api;p(cal.ns[namespace], ar);p(cal, ["initNamespace", namespace]);} else p(cal, ar); return;} p(cal, ar); }; })(window, "https://app.cal.com/embed/embed.js", "init");
  Cal("init", "30min", {origin:"https://app.cal.com"});

  Cal.ns["30min"]("inline", {
    elementOrSelector:"#my-cal-inline-30min",
    config: {"layout":"month_view","useSlotsViewOnSmallScreen":"true","theme":"light"},
    calLink: "okanlulleci/30min",
  });

  Cal.ns["30min"]("ui", {"theme":"light","styles":{"branding":{"brandColor":"#9C1006"}},"hideEventTypeDetails":true,"layout":"month_view"});
</script>

</Layout>

<style>
  .container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 1.25rem;
  }

  .section {
    padding: 4rem 0;
  }

  .page-title {
    font-size: clamp(1.75rem, 6vw, 2.75rem);
    margin-bottom: 3rem;
  }

  .contact-block {
    margin-bottom: 4rem;
  }

  .contact-block--last {
    margin-bottom: 0;
  }

  .block-title {
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: 1rem;
  }

  .block-desc {
    color: var(--color-steel);
    margin-bottom: 1.5rem;
    font-size: 0.95rem;
  }

  .form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .form__group {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .form__group label {
    font-family: var(--font-heading);
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-dark);
  }

  .form__group input,
  .form__group textarea {
    font-family: var(--font-body);
    font-size: 1rem;
    padding: 0.75rem 1rem;
    border: 1px solid var(--color-sage);
    border-radius: 2px;
    background-color: var(--color-white);
    color: var(--color-dark);
    outline: none;
    transition: border-color 0.2s;
  }

  .form__group input:focus,
  .form__group textarea:focus {
    border-color: var(--color-dark);
  }

  .btn {
    align-self: flex-start;
    display: inline-block;
    background-color: var(--color-red);
    color: var(--color-white);
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 0.9rem;
    padding: 0.75rem 1.75rem;
    border: none;
    border-radius: 2px;
    cursor: pointer;
    transition: opacity 0.2s;
  }

  .btn:hover { opacity: 0.85; }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: start;
  }

  @media (min-width: 900px) {
    .contact-grid {
      grid-template-columns: 1fr 770px;
    }
  }

  .cal-header {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-bottom: 1rem;
    padding-left: 1.6rem;
    padding-right: 1.3rem;
  }

  @media (min-width: 900px) {
    .cal-header {
      flex-direction: row;
      align-items: baseline;
      justify-content: space-between;
      gap: 1rem;
    }
  }

  .cal-header .block-desc {
    margin-bottom: 0;
    text-align: left;
  }

  @media (min-width: 900px) {
    .cal-header .block-desc {
      text-align: right;
    }
  }

  .cal-wrapper {
    width: 100%;
  }
</style>
